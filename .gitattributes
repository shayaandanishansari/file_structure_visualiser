# Tell GitHub to ignore platform-specific native code when calculating language statistics
windows/**/* linguist-detectable=false
linux/**/* linguist-detectable=false
macos/**/* linguist-detectable=false

# Also ignore build artifacts
build/ export-ignore
**/build/ export-ignore

# Ignore generated plugin registrant files
**/generated_plugin_registrant.* linguist-detectable=false

# Additional generated files
**/generated_plugins.* linguist-detectable=false
**/Pods/**/* linguist-detectable=false
ios/.symlinks/**/* linguist-detectable=false
